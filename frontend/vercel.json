{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "framework": "vite",
    "redirects": [
        {
            "source": "/(.*)",
            "has": [
                {
                    "type": "host",
                    "value": "www.codemande.com"
                }
            ],
            "destination": "https://codemande.com/$1",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}