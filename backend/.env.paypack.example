# Paypack Configuration Template
# Copy these to your .env file and fill in with your actual values

# Paypack API Credentials
# Get these from https://payments.paypack.rw dashboard
PAYPACK_CLIENT_ID=your_client_id_here
PAYPACK_CLIENT_SECRET=your_client_secret_here
PAYPACK_WEBHOOK_SECRET=your_webhook_secret_here

# Paypack Environment
# Use 'development' for testing, 'production' for live
PAYPACK_ENVIRONMENT=production

# Paypack API base URL
PAYPACK_BASE_URL=https://payments.paypack.rw/api

# Your Webhook URL (where Paypack will send payment updates)
# Example: https://yourdomain.com/api/payments/webhook
PAYPACK_WEBHOOK_URL=https://yourdomain.com/api/payments/webhook
